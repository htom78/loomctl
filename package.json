{
  "name": "loomctl",
  "version": "0.1.0",
  "description": "Operator CLI and HTTP control plane for a v3-style cloud agentic dev platform with a first-party harness loop.",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "bin": {
    "loom": "dist/index.js",
    "loomd": "dist/loomd.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "pretest": "npm run build",
    "test": "tsx --test --test-concurrency=1 tests/**/*.test.ts",
    "staging:up": "node scripts/staging-up.mjs",
    "staging:smoke": "node scripts/staging-two-instance.mjs",
    "staging:down": "docker compose -f deploy/staging/compose.yml down",
    "production:check": "npm run build && node scripts/production-check.mjs",
    "soak": "LOOM_SOAK=1 node --expose-gc --import tsx --test tests/soak.test.ts",
    "desktop:dev": "npm run api:build && npm run dev --workspace @loom/desktop",
    "desktop:build": "npm run api:build && npm run build --workspace @loom/desktop",
    "desktop:bundle": "npm run api:build && npm run bundle --workspace @loom/desktop",
    "desktop:tauri": "npm run tauri --workspace @loom/desktop",
    "api:build": "npm run build --workspace @loom/api",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "execa": "^9.5.1",
    "jose": "^6.2.3",
    "pg": "^8.22.0",
    "redis": "^6.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/pg": "^8.20.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
