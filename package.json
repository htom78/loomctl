    "dev": "tsx src/index.ts",
    "test": "tsx --test --test-concurrency=1 tests/**/*.test.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "execa": "^9.5.1"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
