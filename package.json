{
  "name": "loomctl",
  "version": "0.1.0",
  "description": "Operator CLI and HTTP control plane for a v3-style cloud agentic dev platform with a first-party harness loop.",
  "type": "module",
  "bin": {
    "loom": "dist/index.js",
    "loomd": "dist/loomd.js"
  },
  "scripts": {
