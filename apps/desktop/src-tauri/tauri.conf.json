{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Loom Desktop",
  "version": "0.1.0",
  "identifier": "dev.loom.desktop",
  "build": {
    "beforeDevCommand": "npm run web:dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run web:build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Loom Desktop",
        "width": 1440,
        "height": 900,
        "minWidth": 1180,
        "minHeight": 680,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://* https://*; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
