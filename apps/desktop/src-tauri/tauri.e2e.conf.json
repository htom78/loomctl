  "app": {
    "withGlobalTauri": true,
    "security": {
      "capabilities": [
        "default",
        {
          "identifier": "e2e-webdriver",
          "description": "Feature-gated WebDriver permissions for installed-app tests",
          "windows": ["main"],
          "permissions": [
            "core:default",
            "core:window:default",
            "wdio:default",
            "wdio-webdriver:default"
          ]
        }
      ]
    }
  }
}
